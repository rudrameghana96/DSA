class Solution:
    def permuteUnique(self, nums):
        result = []
        nums.sort()   # Sort to handle duplicates
        used = [False] * len(nums)

        def backtrack(path):
            # If permutation is complete
            if len(path) == len(nums):
                result.append(path[:])
                return

            for i in range(len(nums)):

                # Skip already used elements
                if used[i]:
                    continue

                # Skip duplicates
                if i > 0 and nums[i] == nums[i - 1] and not used[i - 1]:
                    continue

                # Choose element
                used[i] = True
                path.append(nums[i])

                # Recur
                backtrack(path)

                # Backtrack
                path.pop()
                used[i] = False

        backtrack([])
        return result
