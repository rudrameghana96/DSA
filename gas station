class Solution:
    def canCompleteCircuit(self, gas, cost):
        total_gas = 0
        total_cost = 0
        tank = 0
        start = 0

        for i in range(len(gas)):
            total_gas += gas[i]
            total_cost += cost[i]

            tank += gas[i] - cost[i]

            # If tank becomes negative, current start is invalid
            if tank < 0:
                start = i + 1
                tank = 0

        # If total gas is less than total cost, journey is impossible
        if total_gas < total_cost:
            return -1

        return start


# Example Usage
gas = [1, 2, 3, 4, 5]
cost = [3, 4, 5, 1, 2]

obj = Solution()
print(obj.canCompleteCircuit(gas, cost))  # Output: 3
